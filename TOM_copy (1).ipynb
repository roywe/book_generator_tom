        "    'פ': '⠏', #P\n",
        "}\n",
        "\n",
        "VOWEL_TO_BRAILLE = {\n",
        "    HOLAM: '⠕', # ו עם חולם\n",
        "    SHURUK: '⠥', # ו עם שורוק\n",
        "    HIRIK: '⠊',   # י עם חיריק\n",
