        "def convert_to_braille(text):\n",
        "    result = []\n",
        "    i = 0\n",
        "\n",
        "    while i < len(text):\n",
        "        ch = text[i]\n",
        "\n",
        "        if 'א' <= ch <= 'ת':\n",
        "            base = ch\n",
        "            marks = []\n",
        "            i += 1\n",
        "\n",
        "            # אוספים סימנים לוגיים\n",
        "            while i < len(text) and '\\u0591' <= text[i] <= '\\u05C7':\n",
        "                marks.append(text[i])\n",
        "                i += 1\n",
        "\n",
        "            result.append(letter_to_braille(base, marks))\n",
        "        else:\n",
        "            result.append(ch)\n",
        "            i += 1\n",
        "\n",
        "    return \"\".join(result)"
      ]
    },
