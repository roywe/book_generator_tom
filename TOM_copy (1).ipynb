        "# Braille\n",
        "DAGESH = '\\u05BC'\n",
        "HIRIK = '\\u05B4'\n",
        "HOLAM = '\\u05B9'\n",
        "SHURUK = '\\u05BB'\n",
        "SHIN_DOT = '\\u05C2'\n",
